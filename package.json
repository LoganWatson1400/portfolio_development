{
  "name": "portfolio2",
  "private": true,
  "version": "1.0.0",
  "homepage": "https://loganwatson1400.github.io",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && touch build/.nojekyll && gh-pages -d build -r https://github.com/loganwatson1400/loganwatson1400.github.io.git -b main --dotfiles",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^0.0.17",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "gh-pages": "^6.3.0",
    "svelte": "^5.48.2",
    "svelte-check": "^4.3.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "cheerio": "^1.2.0"
  }
}
